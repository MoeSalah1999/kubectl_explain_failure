{
  "pod": {
    "metadata": {
      "name": "secret-missing-pod",
      "namespace": "default"
    },
    "spec": {
      "containers": [
        {
          "name": "app",
          "image": "nginx:1.27",
          "envFrom": [
            {
              "secretRef": {
                "name": "app-secret"
              }
            }
          ],
          "volumeMounts": [
            {
              "name": "app-secret-volume",
              "mountPath": "/etc/app/secret"
